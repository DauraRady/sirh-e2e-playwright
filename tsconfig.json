{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": ["pages/**/*.ts", "fixtures/**/*.ts", "helpers/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
